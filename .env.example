# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.

# Newsletter / email provider (e.g. Resend, Mailchimp, ConvertKit)
# NEWSLETTER_API_KEY=

# WhatsApp number for FloatingButtons (format: country code + number, no +)
# NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Site URL (used for OG tags and canonical URLs)
# NEXT_PUBLIC_SITE_URL=https://amfire.in
